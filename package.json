{
  "name": "agent-farm-cli",
  "version": "0.1.4",
  "description": "Parallel agent farm CLI with queue/worker/review loops",
  "type": "module",
  "main": "dist/interfaces/cli/index.js",
  "bin": {
    "agent-farm": "dist/interfaces/cli/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/interfaces/cli/index.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run check && npm run test && npm run build",
    "release": "node scripts/release.mjs",
    "agent-farm": "node ./dist/interfaces/cli/index.js",
    "agent-farm:dev": "tsx src/interfaces/cli/index.ts",
    "farm:init": "npm run build && node ./dist/interfaces/cli/index.js project init --target-dir . --force --no-interactive --storage sqlite --environments cursor --executor opencode --workers 4",
    "farm:dispatch": "bash scripts/agent-farm-dispatch.sh",
    "farm:insights": "node ./dist/interfaces/cli/index.js insights",
    "farm:doctor": "node ./dist/interfaces/cli/index.js doctor"
  },
  "keywords": [
    "agent",
    "queue",
    "cli",
    "parallel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
